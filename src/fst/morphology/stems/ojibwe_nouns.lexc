!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Class=NAD_Vw_Flags
@R.Prefix.G@ NAD_Class=NAD_Vw_Flags_Prefix=G ;
@R.Prefix.N@ NAD_Class=NAD_Vw_Flags_Prefix=N ;
