!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD, Class: NAD_VV                                         !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Class=NAD_VV_Boundary
0:%>%> NAD_Class=NAD_VV_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD, Class: NAD_VV                                         !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Class=NAD_VV_Flags
@R.Prefix.G@ NAD_Class=NAD_VV_Flags_Prefix=G ;
@R.Prefix.N@ NAD_Class=NAD_VV_Flags_Prefix=N ;
@R.Prefix.W@ NAD_Class=NAD_VV_Flags_Prefix=W ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD, Class: NAD_VV                                         !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=N                                           !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Class=NAD_VV_Flags_Prefix=N
@U.Order.Other@ NAD_Class=NAD_VV_Prefix=N_Order=Other_Endings ;

