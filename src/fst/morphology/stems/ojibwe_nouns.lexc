+NI+Pret+LocDist:iibanikaang EncliticRoot ;
+NI+Pret+Pl:iibanen EncliticRoot ;
+NI+Pret+Pl:iibaniin EncliticRoot ;
+NI+Pret+Sg:iiban EncliticRoot ;
+NI+Sg:i2 EncliticRoot ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_ShortCy                                      !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NI                                          !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_ShortCy_Flags_Prefix=NI
@U.Order.Other@ NI_Class=NI_ShortCy_Prefix=NI_Order=Other_Endings ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_ShortCy, Prefix: NI, Order: Other            !
!         Endings                                                              !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_ShortCy_Prefix=NI_Order=Other_Endings
+NI+Dim+Loc+1SgPoss:iinsing EncliticRoot ;
+NI+Dim+Loc+ExclPoss:iinsinaang EncliticRoot ;
