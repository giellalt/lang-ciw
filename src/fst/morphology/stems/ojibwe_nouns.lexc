LEXICON NounRoot
@P.Paradigm.NA@ NA_Prefix ;
@P.Paradigm.NAD@ NAD_Prefix ;
@P.Paradigm.NI@ NI_Prefix ;
@P.Paradigm.NID@ NID_Prefix ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD                                                        !
!         Prefixes                                                             !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Prefix
@P.Prefix.G@:@P.Prefix.G@g NAD_PrefixBoundary ;
@P.Prefix.GI@:@P.Prefix.GI@gi NAD_PrefixBoundary ;
@P.Prefix.N@:@P.Prefix.N@n NAD_PrefixBoundary ;
