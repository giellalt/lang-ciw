!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_C_Flags_Prefix=NONE
@U.Order.Other@ NI_Class=NI_C_Prefix=NONE_Order=Other_Endings ;

