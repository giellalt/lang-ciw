!                                                                              !
!         Paradigm: NAD, Class: NAD_C                                          !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Class=NAD_C_Boundary
0:%>%> NAD_Class=NAD_C_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD, Class: NAD_C                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Class=NAD_C_Flags
@R.Prefix.G@ NAD_Class=NAD_C_Flags_Prefix=G ;
@R.Prefix.N@ NAD_Class=NAD_C_Flags_Prefix=N ;
@R.Prefix.W@ NAD_Class=NAD_C_Flags_Prefix=W ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD, Class: NAD_C                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=N                                           !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Class=NAD_C_Flags_Prefix=N
@U.Order.Other@ NAD_Class=NAD_C_Prefix=N_Order=Other_Endings ;

