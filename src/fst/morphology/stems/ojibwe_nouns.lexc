!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_VV_Flags_Prefix=NONE
@U.Order.Other@ NI_Class=NI_VV_Prefix=NONE_Order=Other_Endings ;

