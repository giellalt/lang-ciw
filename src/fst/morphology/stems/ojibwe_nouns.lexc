!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_aa                                           !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_aa_Boundary
0:%>%> NI_Class=NI_aa_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_aa                                           !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_aa_Flags
@R.Prefix.GI@ NI_Class=NI_aa_Flags_Prefix=GI ;
@R.Prefix.NI@ NI_Class=NI_aa_Flags_Prefix=NI ;
@R.Prefix.NONE@ NI_Class=NI_aa_Flags_Prefix=NONE ;
@R.Prefix.O@ NI_Class=NI_aa_Flags_Prefix=O ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_aa                                           !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NONE                                        !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_aa_Flags_Prefix=NONE
@U.Order.Other@ NI_Class=NI_aa_Prefix=NONE_Order=Other_Endings ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_aa, Prefix: NONE, Order: Other               !
!         Endings                                                              !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_aa_Prefix=NONE_Order=Other_Endings
+NI+Dim+Loc:ensing EncliticRoot ;
+NI+Dim+LocDist:ensikaang EncliticRoot ;
+NI+Dim+Pej+Loc:enzhishing EncliticRoot ;
+NI+Dim+Pej+LocDist:enzhishikaang EncliticRoot ;
