!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_Cw_Boundary
0:%>%> NI_Class=NI_Cw_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_Cw                                           !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_Cw_Flags
@R.Prefix.GI@ NI_Class=NI_Cw_Flags_Prefix=GI ;
@R.Prefix.NI@ NI_Class=NI_Cw_Flags_Prefix=NI ;
@R.Prefix.NONE@ NI_Class=NI_Cw_Flags_Prefix=NONE ;
@R.Prefix.O@ NI_Class=NI_Cw_Flags_Prefix=O ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
