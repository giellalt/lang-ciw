+NI+Pret+Sg:aaban EncliticRoot ;
+NI+Sg: EncliticRoot ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_aa                                           !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NI                                          !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_aa_Flags_Prefix=NI
@U.Order.Other@ NI_Class=NI_aa_Prefix=NI_Order=Other_Endings ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NI, Class: NI_aa, Prefix: NI, Order: Other                 !
!         Endings                                                              !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_aa_Prefix=NI_Order=Other_Endings
+NI+Dim+Loc+1SgPoss:ensing EncliticRoot ;
+NI+Dim+Loc+ExclPoss:ensinaang EncliticRoot ;
