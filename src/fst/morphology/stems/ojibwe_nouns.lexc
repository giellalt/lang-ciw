!                                                                              !
!         Paradigm: NID, Class: NID_aa                                         !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NID_Class=NID_aa_Boundary
0:%>%> NID_Class=NID_aa_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NID, Class: NID_aa                                         !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NID_Class=NID_aa_Flags
@R.Prefix.G@ NID_Class=NID_aa_Flags_Prefix=G ;
@R.Prefix.N@ NID_Class=NID_aa_Flags_Prefix=N ;
@R.Prefix.W@ NID_Class=NID_aa_Flags_Prefix=W ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
