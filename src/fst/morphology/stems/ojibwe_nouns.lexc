0:%>%> NAD_Class=NAD_Vw_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD, Class: NAD_Vw                                         !
!         Flag diacritic governing combinations between                        !
