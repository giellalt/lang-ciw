LEXICON NounRoot
@P.Paradigm.NA@ NA_Prefix ;
@P.Paradigm.NAD@ NAD_Prefix ;
@P.Paradigm.NI@ NI_Prefix ;
@P.Paradigm.NID@ NID_Prefix ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD                                                        !
!         Prefixes                                                             !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_Prefix
@P.Prefix.G@:@P.Prefix.G@g NAD_PrefixBoundary ;
@P.Prefix.GI@:@P.Prefix.GI@gi NAD_PrefixBoundary ;
@P.Prefix.N@:@P.Prefix.N@n NAD_PrefixBoundary ;
@P.Prefix.NI@:@P.Prefix.NI@ni NAD_PrefixBoundary ;
@P.Prefix.O@:@P.Prefix.O@o NAD_PrefixBoundary ;
@P.Prefix.W@:@P.Prefix.W@w NAD_PrefixBoundary ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NAD                                                        !
!         Morpheme boundary between prefix and stem                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NAD_PrefixBoundary
0:%<%< PrenounRoot ;

LEXICON NounStems
@R.Paradigm.NA@ NA_Stems ;
@R.Paradigm.NAD@ NAD_Stems ;
@R.Paradigm.NI@ NI_Stems ;
@R.Paradigm.NID@ NID_Stems ;

