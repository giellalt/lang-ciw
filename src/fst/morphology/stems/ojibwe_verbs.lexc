!         Paradigm: VAIO, Class: VAIO                                          !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VAIO_Class=VAIO_Boundary
0:%>%> VAIO_Class=VAIO_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VAIO, Class: VAIO                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VAIO_Class=VAIO_Flags
@R.Prefix.GI@ VAIO_Class=VAIO_Flags_Prefix=GI ;
@R.Prefix.GIDW@ VAIO_Class=VAIO_Flags_Prefix=GIDW ;
@R.Prefix.NI@ VAIO_Class=VAIO_Flags_Prefix=NI ;
@R.Prefix.NONE@ VAIO_Class=VAIO_Flags_Prefix=NONE ;
@R.Prefix.O@ VAIO_Class=VAIO_Flags_Prefix=O ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VAIO, Class: VAIO                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NONE                                        !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VAIO_Class=VAIO_Flags_Prefix=NONE
@U.Order.Cnj@ VAIO_Class=VAIO_Prefix=NONE_Order=Cnj_Endings ;
@U.Order.Ind@ VAIO_Class=VAIO_Prefix=NONE_Order=Ind_Endings ;
@U.Order.Other@ VAIO_Class=VAIO_Prefix=NONE_Order=Other_Endings ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
