!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTA, Class: VTA_C                                          !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTA_Class=VTA_C_Boundary
+VTA+Recip/di:0%>%>di VAI_Class=VAI_rcp_Boundary ;
+VTA+Reflex/dizo:0%>%>dizo VAI_Class=VAI_rfx_Boundary ;
0:%>%> VTA_Class=VTA_C_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTA, Class: VTA_C                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTA_Class=VTA_C_Flags
@R.Prefix.%<CHCNJ%>@ VTA_Class=VTA_C_Flags_Prefix=%<CHCNJ%> ;
@R.Prefix.GI@ VTA_Class=VTA_C_Flags_Prefix=GI ;
@R.Prefix.NI@ VTA_Class=VTA_C_Flags_Prefix=NI ;
@R.Prefix.NONE@ VTA_Class=VTA_C_Flags_Prefix=NONE ;
@R.Prefix.O@ VTA_Class=VTA_C_Flags_Prefix=O ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTA, Class: VTA_C                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NONE                                        !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTA_Class=VTA_C_Flags_Prefix=NONE
@U.Order.Cnj@ VTA_Class=VTA_C_Prefix=NONE_Order=Cnj_Endings ;
@U.Order.Ind@ VTA_Class=VTA_C_Prefix=NONE_Order=Ind_Endings ;
@U.Order.Other@ VTA_Class=VTA_C_Prefix=NONE_Order=Other_Endings ;

