!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VAIPL, Class: VAIPL_VV                                     !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VAIPL_Class=VAIPL_VV_Boundary
0:%>%> VAIPL_Class=VAIPL_VV_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VAIPL, Class: VAIPL_VV                                     !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VAIPL_Class=VAIPL_VV_Flags
@R.Prefix.GI@ VAIPL_Class=VAIPL_VV_Flags_Prefix=GI ;
@R.Prefix.NI@ VAIPL_Class=VAIPL_VV_Flags_Prefix=NI ;
@R.Prefix.NONE@ VAIPL_Class=VAIPL_VV_Flags_Prefix=NONE ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VAIPL, Class: VAIPL_VV                                     !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NONE                                        !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VAIPL_Class=VAIPL_VV_Flags_Prefix=NONE
@U.Order.Cnj@ VAIPL_Class=VAIPL_VV_Prefix=NONE_Order=Cnj_Endings ;
@U.Order.Ind@ VAIPL_Class=VAIPL_VV_Prefix=NONE_Order=Ind_Endings ;
@U.Order.Other@ VAIPL_Class=VAIPL_VV_Prefix=NONE_Order=Other_Endings ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VAIPL, Class: VAIPL_VV, Prefix: NONE, Order: Cnj           !
!         Endings                                                              !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VAIPL_Class=VAIPL_VV_Prefix=NONE_Order=Cnj_Endings
+VAIPL+Cnj+Neg+Dub+2PlSubj:siiwegwen EncliticRoot ;
+VAIPL+Cnj+Neg+Dub+3PlObvSubj:siinigwen EncliticRoot ;
+VAIPL+Cnj+Neg+Dub+3PlProxSubj:siiwaagwen EncliticRoot ;
+VAIPL+Cnj+Neg+Dub+ExclSubj:siiwaangen EncliticRoot ;
+VAIPL+Cnj+Neg+Dub+InclSubj:siiwangen EncliticRoot ;
+VAIPL+Cnj+Neg+DubPrt+2PlSubj:siiwegibanen EncliticRoot ;
+VAIPL+Cnj+Neg+DubPrt+3PlObvSubj:siinigobanen EncliticRoot ;
+VAIPL+Cnj+Neg+DubPrt+3PlProxSubj:siiwaagobanen EncliticRoot ;
+VAIPL+Cnj+Neg+DubPrt+ExclSubj:siiwaangibanen EncliticRoot ;
