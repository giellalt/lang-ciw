!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTA, Class: VTA_n                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NONE                                        !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTA_Class=VTA_n_Flags_Prefix=NONE
@U.Order.Cnj@ VTA_Class=VTA_n_Prefix=NONE_Order=Cnj_Endings ;
@U.Order.Ind@ VTA_Class=VTA_n_Prefix=NONE_Order=Ind_Endings ;
@U.Order.Other@ VTA_Class=VTA_n_Prefix=NONE_Order=Other_Endings ;

