!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTA, Class: VTA_n                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTA_Class=VTA_n_Flags
@R.Prefix.%<CHCNJ%>@ VTA_Class=VTA_n_Flags_Prefix=%<CHCNJ%> ;
@R.Prefix.GI@ VTA_Class=VTA_n_Flags_Prefix=GI ;
@R.Prefix.NI@ VTA_Class=VTA_n_Flags_Prefix=NI ;
@R.Prefix.NONE@ VTA_Class=VTA_n_Flags_Prefix=NONE ;
