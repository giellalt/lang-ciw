!         Paradigm: NA, Class: NA_ShortC                                       !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NA_Class=NA_ShortC_Flags
@R.Prefix.GI@ NA_Class=NA_ShortC_Flags_Prefix=GI ;
