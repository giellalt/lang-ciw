!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTI, Class: VTI_i                                          !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTI_Class=VTI_i_Boundary
0:%>%> VTI_Class=VTI_i_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTI, Class: VTI_i                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTI_Class=VTI_i_Flags
@R.Prefix.%<CHCNJ%>@ VTI_Class=VTI_i_Flags_Prefix=%<CHCNJ%> ;
@R.Prefix.GI@ VTI_Class=VTI_i_Flags_Prefix=GI ;
@R.Prefix.NI@ VTI_Class=VTI_i_Flags_Prefix=NI ;
@R.Prefix.NONE@ VTI_Class=VTI_i_Flags_Prefix=NONE ;
@R.Prefix.O@ VTI_Class=VTI_i_Flags_Prefix=O ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: VTI, Class: VTI_i                                          !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NONE                                        !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON VTI_Class=VTI_i_Flags_Prefix=NONE
@U.Order.Cnj@ VTI_Class=VTI_i_Prefix=NONE_Order=Cnj_Endings ;
@U.Order.Other@ VTI_Class=VTI_i_Prefix=NONE_Order=Other_Endings ;

