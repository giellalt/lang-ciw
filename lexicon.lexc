!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NI_Class=NI_Cy_Flags_Prefix=NONE
@U.Order.Other@ NI_Class=NI_Cy_Prefix=NONE_Order=Other_Endings ;

