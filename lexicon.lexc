@R.Prefix.NONE@ NA_Class=NA_ShortC_Flags_Prefix=NONE ;
@R.Prefix.O@ NA_Class=NA_ShortC_Flags_Prefix=O ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
