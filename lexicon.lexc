!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NA, Class: NA_C                                            !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NA_Class=NA_C_Boundary
0:%>%> NA_Class=NA_C_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NA, Class: NA_C                                            !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NA_Class=NA_C_Flags
@R.Prefix.GI@ NA_Class=NA_C_Flags_Prefix=GI ;
@R.Prefix.NI@ NA_Class=NA_C_Flags_Prefix=NI ;
@R.Prefix.NONE@ NA_Class=NA_C_Flags_Prefix=NONE ;
@R.Prefix.O@ NA_Class=NA_C_Flags_Prefix=O ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NA, Class: NA_C                                            !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NI                                          !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NA_Class=NA_C_Flags_Prefix=NI
@U.Order.Other@ NA_Class=NA_C_Prefix=NI_Order=Other_Endings ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: NA, Class: NA_C, Prefix: NI, Order: Other                  !
!         Endings                                                              !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON NA_Class=NA_C_Prefix=NI_Order=Other_Endings
+NA+Dim+Loc+1SgPoss:ensing EncliticRoot ;
+NA+Dim+Loc+ExclPoss:ensinaang EncliticRoot ;
+NA+Dim+LocDist+1SgPoss:ensikaang EncliticRoot ;
+NA+Dim+LocDist+ExclPoss:ensinaakaang EncliticRoot ;
+NA+Dim+ObvPl+1SgPoss:ensa' EncliticRoot ;
+NA+Dim+ObvPl+1SgPoss:ensan EncliticRoot ;
+NA+Dim+ObvPl+ExclPoss:ensinaani' EncliticRoot ;
+NA+Dim+ObvPl+ExclPoss:ensinaanin EncliticRoot ;
+NA+Dim+ObvSg+1SgPoss:ensan EncliticRoot ;
+NA+Dim+ObvSg+ExclPoss:ensinaanin EncliticRoot ;
+NA+Dim+Pej+Loc+1SgPoss:enzhishing EncliticRoot ;
+NA+Dim+Pej+Loc+ExclPoss:enzhishinaang EncliticRoot ;
+NA+Dim+Pej+LocDist+1SgPoss:enzhishikaang EncliticRoot ;
+NA+Dim+Pej+LocDist+ExclPoss:enzhishinaakaang EncliticRoot ;
+NA+Dim+Pej+ObvPl+1SgPoss:enzhisha' EncliticRoot ;
+NA+Dim+Pej+ObvPl+1SgPoss:enzhishan EncliticRoot ;
+NA+Dim+Pej+ObvPl+ExclPoss:enzhishinaani' EncliticRoot ;
+NA+Dim+Pej+ObvPl+ExclPoss:enzhishinaanin EncliticRoot ;
