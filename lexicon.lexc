LEXICON Root
AdverbRoot ;
NounRoot ;
NumeralRoot ;
ParticleRoot ;
PronounRoot ;
ProperNounRoot ;
VerbRoot ;


!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!                         !!
!!   CL lexicons start     !!
!!                         !!
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON EncliticRoot
enCLBoundary ;
# ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!!                         !!
!!        enCLitic         !!
!!                         !!
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON enCL
+CL%/ADVConj%/dash:sh # ;


LEXICON enCLBoundary
0:- enCL ;
LEXICON AdverbRoot
@P.Paradigm.ADVConj@ ADVConj_Prefix ;
@P.Paradigm.ADVDeg@ ADVDeg_Prefix ;
@P.Paradigm.ADVDisc@ ADVDisc_Prefix ;
@P.Paradigm.ADVDub@ ADVDub_Prefix ;
@P.Paradigm.ADVGram@ ADVGram_Prefix ;
@P.Paradigm.ADVInter@ ADVInter_Prefix ;
@P.Paradigm.ADVLoc@ ADVLoc_Prefix ;
@P.Paradigm.ADVMan@ ADVMan_Prefix ;
@P.Paradigm.ADVNeg@ ADVNeg_Prefix ;
@P.Paradigm.ADVPred@ ADVPred_Prefix ;
@P.Paradigm.ADVQnt@ ADVQnt_Prefix ;
@P.Paradigm.ADVTmp@ ADVTmp_Prefix ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: ADVConj                                                    !
!         Prefixes                                                             !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON ADVConj_Prefix
@P.Prefix.NONE@ ADVConj_PrefixBoundary ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: ADVConj                                                    !
!         Morpheme boundary between prefix and stem                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON ADVConj_PrefixBoundary
0:%<%< PreadverbRoot ;

LEXICON AdverbStems
@R.Paradigm.ADVConj@ ADVConj_Stems ;
@R.Paradigm.ADVDeg@ ADVDeg_Stems ;
@R.Paradigm.ADVDisc@ ADVDisc_Stems ;
@R.Paradigm.ADVDub@ ADVDub_Stems ;
@R.Paradigm.ADVGram@ ADVGram_Stems ;
@R.Paradigm.ADVInter@ ADVInter_Stems ;
@R.Paradigm.ADVLoc@ ADVLoc_Stems ;
@R.Paradigm.ADVMan@ ADVMan_Stems ;
@R.Paradigm.ADVNeg@ ADVNeg_Stems ;
@R.Paradigm.ADVPred@ ADVPred_Stems ;
@R.Paradigm.ADVQnt@ ADVQnt_Stems ;
@R.Paradigm.ADVTmp@ ADVTmp_Stems ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: ADVConj                                                    !
!         Stems                                                                !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON ADVConj_Stems
ashi:ashiw2 ADVConj_Class=ADVConj_Boundary ;
dash ADVConj_Class=ADVConj_Boundary ;
gaye ADVConj_Class=ADVConj_Boundary ;
ge ADVConj_Class=ADVConj_Boundary ;
gemaa ADVConj_Class=ADVConj_Boundary ;
gomaa% gaye ADVConj_Class=ADVConj_Boundary ;
idash ADVConj_Class=ADVConj_Boundary ;
igaye ADVConj_Class=ADVConj_Boundary ;
mii% dash ADVConj_Class=ADVConj_Boundary ;
miinawaa ADVConj_Class=ADVConj_Boundary ;
shi:shiw2 ADVConj_Class=ADVConj_Boundary ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: ADVConj, Class: ADVConj                                    !
!         Morpheme boundary between stem and suffix                            !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON ADVConj_Class=ADVConj_Boundary
0:%>%> ADVConj_Class=ADVConj_Flags ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: ADVConj, Class: ADVConj                                    !
!         Flag diacritic governing combinations between                        !
!         prefix and ending                                                    !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON ADVConj_Class=ADVConj_Flags
@R.Prefix.NONE@ ADVConj_Class=ADVConj_Flags_Prefix=NONE ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: ADVConj, Class: ADVConj                                    !
!         Flag diacritic governing combinations between                        !
!         prefix and ending_Prefix=NONE                                        !
!                                                                              !
!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!

LEXICON ADVConj_Class=ADVConj_Flags_Prefix=NONE
@U.Order.Other@ ADVConj_Class=ADVConj_Prefix=NONE_Order=Other_Endings ;

!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
!                                                                              !
!         Paradigm: ADVConj, Class: ADVConj, Prefix: NONE, Order: Other        !
!         Endings                                                              !
!                                                                              !
